{
  "name": "loom",
  "private": true,
  "version": "0.1.0",
  "description": "Loom - supply the game engine for on-chain worlds, as a protocol.",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "test:engine": "cargo test --manifest-path engine-core/Cargo.toml",
    "test:sdk": "pnpm --filter @loom/sdk test",
    "test:world": "pnpm --filter @loom/world-smallholm test",
    "test:ts": "pnpm -r --workspace-concurrency=1 test",
    "test": "pnpm run test:engine && pnpm run test:ts",
    "world": "pnpm --filter @loom/world-smallholm start"
  }
}
